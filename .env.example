# ─────────────────────────────────────────────
# HireRight AI — Environment Variables
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────

# Google Gemini (required — used for embeddings + all LLM calls)
GOOGLE_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768

# Supabase (required — vector DB + all persistent storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# GitHub (optional — enriches candidate profiles with repo data)
GITHUB_TOKEN=your_github_personal_access_token_here

# Tavily (required for live job scraping)
TAVILY_API_KEY=your_tavily_api_key_here

# MCP Server URLs (defaults work for local dev — change for Docker/cloud)
MCP_GITHUB_SERVER_URL=http://localhost:8001
MCP_JOBMARKET_SERVER_URL=http://localhost:8002

# Agent Configuration
MAX_DEBATE_ROUNDS=3
REDEBATE_THRESHOLD=0.30
